{
  "name": "boothrflow",
  "version": "0.0.0",
  "private": true,
  "license": "Apache-2.0",
  "description": "Local-first, open-source voice dictation. Push-to-talk, format, paste anywhere.",
  "type": "module",
  "engines": {
    "node": ">=22",
    "pnpm": ">=9"
  },
  "packageManager": "pnpm@10.0.0",
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "lefthook",
      "msw"
    ]
  },
  "scripts": {
    "dev": "tauri dev",
    "build": "tauri build",
    "dev:vite": "vite",
    "build:vite": "vite build",
    "preview": "vite preview",
    "tauri": "tauri",
    "gen": "echo 'tauri-specta + bindings generation lands in Phase 1 W3 — see DECISIONS.md ADR-007' && exit 0",
    "test": "pnpm test:fe && pnpm test:rust",
    "test:fe": "vitest run",
    "test:fe:watch": "vitest",
    "test:fe:browser": "vitest run --project component",
    "test:rust": "cd src-tauri && cargo nextest run --no-default-features --features test-fakes",
    "test:rust:real": "cd src-tauri && cargo nextest run",
    "test:rust:doc": "cd src-tauri && cargo test --doc --no-default-features --features test-fakes",
    "test:e2e": "playwright test",
    "check": "pnpm check:types && pnpm check:lint && pnpm check:format && pnpm check:rust",
    "check:types": "svelte-check --tsconfig ./tsconfig.json --threshold warning",
    "check:lint": "eslint src",
    "check:format": "prettier --check .",
    "check:rust": "cd src-tauri && cargo fmt --check && cargo clippy --no-default-features --features test-fakes --all-targets -- -D warnings",
    "fix": "eslint src --fix && prettier --write . && cd src-tauri && cargo fmt",
    "deny": "cd src-tauri && cargo deny check",
    "prepare": "lefthook install"
  },
  "dependencies": {
    "@tanstack/svelte-query": "^5.62.0",
    "@tauri-apps/api": "^2.10.0",
    "@tauri-apps/plugin-autostart": "^2.5.1",
    "@tauri-apps/plugin-clipboard-manager": "^2.3.2",
    "@tauri-apps/plugin-global-shortcut": "^2.3.1",
    "@tauri-apps/plugin-log": "^2.7.1",
    "@tauri-apps/plugin-opener": "^2.5.2",
    "@tauri-apps/plugin-os": "^2.3.2",
    "@tauri-apps/plugin-process": "^2.3.1",
    "@tauri-apps/plugin-store": "^2.4.1",
    "clsx": "^2.1.1",
    "lucide-svelte": "^0.473.0",
    "tailwind-merge": "^2.5.5",
    "wellcrafted": "^0.35.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.16.0",
    "@playwright/test": "^1.49.0",
    "@sveltejs/vite-plugin-svelte": "^5.0.0",
    "globals": "^15.14.0",
    "@tailwindcss/vite": "^4.1.0",
    "@tauri-apps/cli": "^2.10.0",
    "@types/node": "^22.10.0",
    "@vitest/browser": "^3.0.0",
    "eslint": "^9.16.0",
    "eslint-plugin-svelte": "^3.0.0",
    "lefthook": "^1.10.0",
    "playwright": "^1.49.0",
    "prettier": "^3.4.0",
    "prettier-plugin-svelte": "^3.3.0",
    "svelte": "^5.20.0",
    "svelte-check": "^4.1.0",
    "tailwindcss": "^4.1.0",
    "typescript": "~5.7.0",
    "typescript-eslint": "^8.18.0",
    "vite": "^6.4.0",
    "vitest": "^3.0.0",
    "vitest-browser-svelte": "^0.1.0"
  }
}
