{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "boothrflow",
  "version": "0.0.0",
  "identifier": "dev.boothe.boothrflow",
  "build": {
    "beforeDevCommand": "pnpm dev:vite",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build:vite",
    "frontendDist": "../dist"
  },
  "app": {
    "macOSPrivateApi": true,
    "windows": [
      {
        "title": "boothrflow",
        "width": 800,
        "height": 600,
        "resizable": true,
        "fullscreen": false,
        "decorations": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": "all",
    "category": "Productivity",
    "shortDescription": "Local-first voice dictation",
    "longDescription": "Push-to-talk voice dictation that runs entirely on your machine. Streaming STT, LLM cleanup with styles, paste anywhere, searchable history. All local.",
    "homepage": "https://github.com/ericboothe/boothrflow",
    "license": "Apache-2.0",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "minimumSystemVersion": "10.15",
      "hardenedRuntime": true,
      "entitlements": null,
      "signingIdentity": null
    },
    "linux": {
      "appimage": {
        "bundleMediaFramework": true
      }
    },
    "windows": {
      "webviewInstallMode": { "type": "embedBootstrapper" },
      "nsis": {
        "installMode": "currentUser",
        "compression": "lzma"
      }
    }
  },
  "plugins": {}
}
